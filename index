                    </div>
                `;
                insertBotReply(profilePayload);
            } else if(type === 'cari_surah' || type === 'cari_ayat') {
                insertBotReply("Ketikkan langsung kata kunci nama surah yang Anda tuju pada kolom teks chat ini.");
