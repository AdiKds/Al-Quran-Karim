    <script>
        const API_URL = 'https://raw.githubusercontent.com/bachors/Al-Quran-ID-API/refs/heads/master/offline/data.json';
        let allSurahData = [];
        let isScreensaverActive = false;
        let currentQuoteIndex = 0;
        let currentSelectedSurahNomor = 1;
        let db; 
        let lastActiveIndex = -1;

        const islamicQuotes = [
            "\"Maka sesungguhnya beserta kesulitan ada kemudahan.\" (QS. Al-Insyirah: 5)",
            "\"Cukuplah Allah bagi kami, dan Dia adalah sebaik-baik pelindung.\" (QS. Ali 'Imran: 173)",
            "\"Dan Dia mendapatimu sebagai seorang yang bingung, lalu Dia memberikan petunjuk.\" (QS. Ad-Duha: 7)",
            "\"Janganlah kamu berduka cita, sesungguhnya Allah beserta kita.\" (QS. At-Taubah: 40)",
            "\"Dan hanya kepada Tuhanmulah hendaknya kamu berharap.\" (QS. Al-Insyirah: 8)"
        ];

        // --- INDEXEDDB STORAGE SYSTEM ---
        function initIndexedDB() {
            const request = indexedDB.open("AlQuranAudioDB", 1);
            request.onupgradeneeded = function(e) {
                let database = e.target.result;
                if (!database.objectStoreNames.contains("audio_files")) {
                    database.createObjectStore("audio_files", { keyPath: "surah_nomor" });
                }
            };
            request.onsuccess = function(e) {
                db = e.target.result;
                fetchAlQuran();
            };
            request.onerror = function() {
                console.error("Gagal menginisialisasi sistem database internal browser.");
                fetchAlQuran();
            };
        }

        // --- SINKRONISASI JAM & HARI ---
        function updateDateTime() {
            const sekarang = new Date();
            const daysArr = ["Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"];
            const monthsArr = ["Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Agu", "Sep", "Okt", "Nov", "Des"];
            
            const dayStr = `${daysArr[sekarang.getDay()]}, ${sekarang.getDate().toString().padStart(2, '0')} ${monthsArr[sekarang.getMonth()]} ${sekarang.getFullYear()}`;
            const timeStr = `${sekarang.getHours().toString().padStart(2, '0')}:${sekarang.getMinutes().toString().padStart(2, '0')}:${sekarang.getSeconds().toString().padStart(2, '0')}`;
            
            document.getElementById('dashboard-date').innerText = dayStr;
            document.getElementById('dashboard-time').innerText = timeStr;
            document.getElementById('chat-top-day').innerText = dayStr;
            document.getElementById('chat-top-clock').innerText = timeStr + " WIB";

            if(isScreensaverActive) {
                document.getElementById('scClockDisplay').innerText = timeStr;
                document.getElementById('scDateDisplay').innerText = dayStr + " | WIB";
            }
        }
        setInterval(updateDateTime, 1000);

        // --- MODE TEMA VISUAL ---
        function toggleTheme() {
            const html = document.documentElement;
            const icon = document.getElementById('theme-icon');
            
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                icon.innerText = '🌙';
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                icon.innerText = '☀️';
                localStorage.setItem('theme', 'dark');
            }
        }
        
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            document.getElementById('theme-icon').innerText = '☀️';
        } else {
            document.documentElement.classList.remove('dark');
            document.getElementById('theme-icon').innerText = '🌙';
        }

        // --- LOGIKA WIDGET QUOTES ---
        function updateDashboardQuote() {
            const textEl = document.getElementById('dashboardQuoteText');
            const scTextEl = document.getElementById('islamicScreensaverQuoteText');
            
            if(textEl) {
                textEl.classList.add('quote-hidden');
                setTimeout(() => {
                    textEl.innerText = islamicQuotes[currentQuoteIndex];
                    textEl.classList.remove('quote-hidden');
                }, 300);
            }
            if(scTextEl) {
                scTextEl.innerText = islamicQuotes[currentQuoteIndex];
            }
        }

        function navigateQuote(direction) {
            currentQuoteIndex += direction;
            if (currentQuoteIndex >= islamicQuotes.length) currentQuoteIndex = 0;
            if (currentQuoteIndex < 0) currentQuoteIndex = islamicQuotes.length - 1;
            updateDashboardQuote();
        }

        function toggleFloatingQuotes() {
            const widget = document.getElementById('floatingQuoteWidget');
            if(widget.classList.contains('hidden')) {
                widget.classList.remove('hidden');
                widget.classList.add('flex');
            } else {
                widget.classList.add('hidden');
                widget.classList.remove('flex');
            }
        }

        // --- KEYBOARD ENGINE NAVIGASI INTERAKTIF ---
        window.addEventListener("keydown", function(event) {
            if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA') {
                return;
            }
            if (event.key === "ArrowRight") {
                navigateQuote(1);
            } else if (event.key === "ArrowLeft") {
                navigateQuote(-1);
            }
            if (!isScreensaverActive && allSurahData.length > 0) {
                if (event.key === "ArrowDown") {
                    event.preventDefault();
                    if (currentSelectedSurahNomor < 114) {
                        currentSelectedSurahNomor++;
                        openSurah(currentSelectedSurahNomor);
                        scrollSidebarToActiveElement();
                    }
                } else if (event.key === "ArrowUp") {
                    event.preventDefault();
                    if (currentSelectedSurahNomor > 1) {
                        currentSelectedSurahNomor--;
                        openSurah(currentSelectedSurahNomor);
                        scrollSidebarToActiveElement();
                    }
                }
            }
            if (event.key === "Escape" && isScreensaverActive) {
                deactivateScreensaver();
            }
        });

        function scrollSidebarToActiveElement() {
            const activeButton = document.getElementById(`sidebar-btn-${currentSelectedSurahNomor}`);
            if (activeButton) {
                activeButton.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }

        // --- AUDIO ENGINE ---
        async function playSurahAudio(audioUrlRaw, surahNama, surahNomor, event) {
            if(event) event.stopPropagation();
            
            let finalAudioUrl = audioUrlRaw;
            if(!finalAudioUrl || finalAudioUrl === 'undefined') {
                 finalAudioUrl = `https://equran.nos.wjv-1.neo.id/audio-full/114-misyari-rasyid-al-afasi/${String(surahNomor).padStart(3, '0')}.mp3`;
            }

            const btnPlay = document.getElementById(`btn-play-${surahNomor}`);
            if(btnPlay) btnPlay.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Downloading...`;

            try {
                let audioBlob = await getAudioFromLocalDB(surahNomor);
                if (!audioBlob) {
                    audioBlob = await downloadAndStoreAudio(finalAudioUrl, surahNomor);
                }

                const blobUrl = URL.createObjectURL(audioBlob);
                const playerWidget = document.getElementById('audioPlayerWidget');
                const audioEl = document.getElementById('globalAudio');
                const titleEl = document.getElementById('audioSurahTitle');
                
                playerWidget.classList.remove('hidden');
                playerWidget.classList.add('flex');
                titleEl.innerText = surahNama;
                
                audioEl.src = blobUrl;
                audioEl.play();

                if(btnPlay) btnPlay.innerHTML = `<i class="fa-solid fa-circle-play text-lg"></i> Putar Murottal Surah`;

                lastActiveIndex = -1;
                bindAudioHighlightAndScrollEffect(audioEl, surahNomor);

            } catch (err) {
                console.error("Gagal memproses audio offline:", err);
                if(btnPlay) btnPlay.innerHTML = `<i class="fa-solid fa-circle-play text-lg"></i> Putar Murottal Surah`;
                alert("Memutar langsung dari server hosting...");
                const audioEl = document.getElementById('globalAudio');
                audioEl.src = finalAudioUrl;
                audioEl.play();
                lastActiveIndex = -1;
                bindAudioHighlightAndScrollEffect(audioEl, surahNomor);
            }
        }

        function bindAudioHighlightAndScrollEffect(audioEngine, surahNomor) {
            const boxes = document.querySelectorAll('[id^="ayat-box-"]');
            
            audioEngine.onplay = () => {
                const infoWidget = document.getElementById('surah-info');
                if(infoWidget) infoWidget.classList.add('animate-gold-glow-box');
            };

            audioEngine.ontimeupdate = () => {
                if (boxes.length === 0) return;
                
                const progressPercentage = audioEngine.currentTime / audioEngine.duration;
                const activeIndex = Math.floor(progressPercentage * boxes.length);

                boxes.forEach((box, idx) => {
                    if (idx === activeIndex) {
                        box.classList.add('audio-active-highlight');
                        
                        if (idx !== lastActiveIndex) {
                            lastActiveIndex = idx;
                            const rect = box.getBoundingClientRect();
                            const bufferZone = window.innerHeight - 180;

                            if (rect.bottom > bufferZone || rect.top < 100) {
                                box.scrollIntoView({
                                    behavior: 'smooth',
                                    block: 'center'
                                });
                            }
                        }
                    } else {
                        box.classList.remove('audio-active-highlight');
                    }
                });
            };

            audioEngine.onended = () => {
                boxes.forEach(box => box.classList.remove('audio-active-highlight'));
                const infoWidget = document.getElementById('surah-info');
                if(infoWidget) infoWidget.classList.remove('animate-gold-glow-box');
                lastActiveIndex = -1;
            };
            
            audioEngine.onpause = () => {
                boxes.forEach(box => box.classList.remove('audio-active-highlight'));
            };
        }

        // Unduh Manual Storage Lokal
        async function triggerManualDownload(audioUrlRaw, surahNomor) {
            let finalAudioUrl = audioUrlRaw;
            if(!finalAudioUrl || finalAudioUrl === 'undefined') {
                 finalAudioUrl = `https://equran.nos.wjv-1.neo.id/audio-full/114-misyari-rasyid-al-afasi/${String(surahNomor).padStart(3, '0')}.mp3`;
            }
            
            const btnDl = document.getElementById(`btn-dl-${surahNomor}`);
            if(btnDl) btnDl.innerHTML = `<i class="fa-solid fa-arrows-rotate animate-spin text-lg"></i>`;

            try {
                await downloadAndStoreAudio(finalAudioUrl, surahNomor);
                if(btnDl) {
                    btnDl.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400 text-lg"></i>`;
                    btnDl.title = "Tersimpan di Peramban Lokal";
                }
                alert("Sukses mengunduh & mengunci audio surah ke storage lokal browser!");
            } catch(e) {
                alert("Gagal mengunduh audio lokal.");
                if(btnDl) btnDl.innerHTML = `<i class="fa-solid fa-floppy-disk text-lg"></i>`;
            }
        }

        function getAudioFromLocalDB(surahNomor) {
            return new Promise((resolve, reject) => {
                if (!db) return resolve(null);
                const transaction = db.transaction(["audio_files"], "readonly");
                const store = transaction.objectStore("audio_files");
                const request = store.get(surahNomor);
                request.onsuccess = (e) => {
                    resolve(e.target.result ? e.target.result.blobData : null);
                };
                request.onerror = () => reject(request.error);
            });
        }

        async function downloadAndStoreAudio(url, surahNomor) {
            const response = await fetch(url);
            if (!response.ok) throw new Error("Network error fetching audio resource.");
            const blob = await response.blob();
            
            if (db) {
                const transaction = db.transaction(["audio_files"], "readwrite");
                const store = transaction.objectStore("audio_files");
                store.put({ surah_nomor: surahNomor, blobData: blob, timestamp: Date.now() });
            }
            return blob;
        }

        function checkDownloadStatusInUI(surahNomor) {
            if(!db) return;
            getAudioFromLocalDB(surahNomor).then(blob => {
                const btnDl = document.getElementById(`btn-dl-${surahNomor}`);
                if(blob && btnDl) {
                    btnDl.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400 text-lg"></i>`;
                    btnDl.title = "Tersimpan di Peramban Lokal";
                }
            });
        }

        function closeAudioPlayer() {
            const playerWidget = document.getElementById('audioPlayerWidget');
            const audioEl = document.getElementById('globalAudio');
            audioEl.pause();
            playerWidget.classList.add('hidden');
            playerWidget.classList.remove('flex');
            document.querySelectorAll('[id^="ayat-box-"]').forEach(box => box.classList.remove('audio-active-highlight'));
            lastActiveIndex = -1;
        }

        // --- LOADING ENGINE WITH MUSHAF ANIMATION ---
        async function fetchAlQuran() {
            const progressBar = document.getElementById('loaderProgressBar');
            try {
                progressBar.style.width = '40%';
                const response = await fetch(API_URL);
                if (!response.ok) throw new Error();
                allSurahData = await response.json();
                
                progressBar.style.width = '100%';
                setTimeout(() => {
                    const loader = document.getElementById('globalAppLoader');
                    loader.classList.add('opacity-0');
                    setTimeout(() => loader.classList.add('hidden'), 700);
                    
                    document.getElementById('surah-grid').classList.remove('hidden');
                    renderSurahList(allSurahData);
                    renderSidebarMenu(allSurahData);
                    document.getElementById('surah-counter').innerText = `${allSurahData.length}/114`;
                    updateDashboardQuote();
                    
                    setTimeout(() => toggleFloatingQuotes(), 1000);
                }, 400);
            } catch (error) {
                document.getElementById('globalAppLoader').innerHTML = `
                    <p class="text-red-500 font-semibold p-4 text-center font-mono-tech">⚠️ Gagal sinkronisasi data internal core. Periksa koneksi internet.</p>
                `;
            }
        }

        // --- RENDER COMPONENTS ---
        function renderSurahList(data) {
            const grid = document.getElementById('surah-grid');
            grid.innerHTML = '';
            if(data.length === 0) {
                grid.innerHTML = '<p class="col-span-2 text-center py-8 text-slate-400">Surah tidak terdeteksi...</p>';
                return;
            }
            data.forEach((surah) => {
                const card = document.createElement('div');
                card.id = `surah-card-${surah.nomor}`;
                card.className = 'bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-teal-500 transition-all cursor-pointer flex justify-between items-center group shadow-sm';
                card.setAttribute('onclick', `openSurah(${surah.nomor})`);
                card.innerHTML = `
                    <div class="flex justify-between w-full items-center">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-teal-50 dark:bg-slate-800 text-teal-700 dark:text-teal-400 font-bold flex items-center justify-center rounded-xl text-sm group-hover:bg-teal-600 group-hover:text-white transition-colors shrink-0 shadow-inner">${surah.nomor}</div>
                            <div>
                                <h3 class="font-bold text-slate-800 dark:text-slate-100 text-base group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors flex items-center gap-2">
                                    ${surah.nama}
                                    <button onclick="playSurahAudio('${surah.audio}', '${surah.nama}', ${surah.nomor}, event)" id="btn-play-list-${surah.nomor}" class="w-7 h-7 bg-teal-100 dark:bg-slate-800 text-teal-600 dark:text-teal-400 rounded-full flex items-center justify-center hover:bg-teal-500 hover:text-white transition-all shadow-sm z-10 cursor-pointer" title="Putar Murottal Surah Ini">
                                        <i class="fa-solid fa-volume-high text-[10px]"></i>
                                    </button>
                                </h3>
                                <p class="text-[11px] text-slate-400 dark:text-slate-500 uppercase font-medium mt-0.5">${surah.type} • ${surah.ayat.length} Ayat</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="font-arabic text-xl font-bold text-slate-700 dark:text-slate-200">${surah.asma}</span>
                            <p class="text-xs text-slate-400 dark:text-slate-500 italic mt-1">${surah.arti}</p>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function renderSidebarMenu(surahs) {
            const sidebar = document.getElementById('sidebar-menu');
            sidebar.innerHTML = '';
            surahs.forEach((surah) => {
                const button = document.createElement('button');
                button.id = `sidebar-btn-${surah.nomor}`;
                button.className = 'w-full text-left px-2.5 py-1.5 rounded-xl text-xs font-medium flex justify-between items-center transition-all bg-slate-50/80 hover:bg-teal-50 dark:bg-slate-950 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 hover:text-teal-600 dark:hover:text-teal-400 cursor-pointer border border-transparent';
                button.setAttribute('onclick', `openSurah(${surah.nomor})`);
                button.innerHTML = `
                    <span class="truncate"><b class="text-slate-400 dark:text-slate-600 mr-1 font-mono-tech text-[10px]">${surah.nomor}.</b> ${surah.nama}</span>
                    <span class="font-arabic text-slate-400 dark:text-slate-600">${surah.asma}</span>
                `;
                sidebar.appendChild(button);
            });
        }

        function updateSidebarActiveStyle() {
            for (let i = 1; i <= 114; i++) {
                const btn = document.getElementById(`sidebar-btn-${i}`);
                if (btn) {
                    btn.classList.remove('border-teal-500', 'bg-teal-50/50', 'dark:bg-slate-800/70', 'text-teal-600', 'dark:text-teal-400');
                }
            }
            const activeBtn = document.getElementById(`sidebar-btn-${currentSelectedSurahNomor}`);
            if (activeBtn) {
                activeBtn.classList.add('border-teal-500', 'bg-teal-50/50', 'dark:bg-slate-800/70', 'text-teal-600', 'dark:text-teal-400');
            }
        }

        // --- FITUR TEKS BANTUAN / SUGGESTION PENCARIAN DASBOR ---
        function filterSurahWithSuggestion() {
            const inputEl = document.getElementById('search-input');
            const suggestionBox = document.getElementById('search-suggestions');
            const query = inputEl.value.toLowerCase().trim();
            
            if(!query) {
                suggestionBox.classList.add('hidden');
                renderSurahList(allSurahData);
                return;
            }

            const filtered = allSurahData.filter(surah => 
                surah.nama.toLowerCase().includes(query) || surah.arti.toLowerCase().includes(query)
            );
            
            renderSurahList(filtered);

            // Buka boks teks bantuan autocomplete
            if(filtered.length > 0) {
                suggestionBox.innerHTML = '';
                suggestionBox.classList.remove('hidden');
                
                // Ambil maks 5 surah teratas sebagai bantuan teks bantuan typing
                filtered.slice(0, 5).forEach(surah => {
                    const row = document.createElement('div');
                    row.className = 'p-2.5 text-xs font-semibold cursor-pointer text-slate-700 dark:text-slate-200 hover:bg-teal-50 dark:hover:bg-slate-800 rounded-lg flex justify-between items-center transition-colors border-b border-slate-100 dark:border-slate-800/50 last:border-none';
                    row.innerHTML = `
                        <span>🕌 Surah <b class="text-teal-600 dark:text-teal-400">${surah.nama}</b> <span class="text-slate-400 font-normal">(${surah.arti})</span></span>
                        <span class="font-arabic text-sm text-slate-400">${surah.asma}</span>
                    `;
                    row.onclick = () => {
                        inputEl.value = surah.nama;
                        suggestionBox.classList.add('hidden');
                        openSurah(surah.nomor);
                    };
                    suggestionBox.appendChild(row);
                });
            } else {
                suggestionBox.classList.add('hidden');
            }
        }

        // Klik di luar area rekomendasi otomatis akan menutup dropdown teks bantuan pencarian dasbor
        document.addEventListener('click', function(e) {
            const suggestionBox = document.getElementById('search-suggestions');
            if (e.target.id !== 'search-input') {
                suggestionBox.classList.add('hidden');
            }
        });

        function openSurah(nomorSurah) {
            const surah = allSurahData.find(s => s.nomor == nomorSurah);
            if (!surah) return;
            currentSelectedSurahNomor = nomorSurah;
            updateSidebarActiveStyle();

            document.getElementById('surah-list-section').classList.add('hidden');
            document.getElementById('surah-detail-section').classList.remove('hidden');
            
            document.getElementById('surah-info').innerHTML = `
                <h2 class="text-4xl font-bold font-arabic mb-2">${surah.asma}</h2>
                <h3 class="text-2xl font-bold mb-1">${surah.nomor}. ${surah.nama} (${surah.arti})</h3>
                <p class="text-xs opacity-80 uppercase tracking-widest mb-4">${surah.type} • ${surah.ayat.length} AYAT</p>
                <div class="flex items-center gap-2.5">
                    <button id="btn-play-${surah.nomor}" onclick="playSurahAudio('${surah.audio}', '${surah.nama}', ${surah.nomor})" class="px-5 py-2.5 bg-yellow-500 text-slate-900 font-bold rounded-xl hover:bg-yellow-400 transition-all shadow-lg flex items-center gap-2 text-sm cursor-pointer border-2 border-yellow-300 active:scale-95">
                        <i class="fa-solid fa-circle-play text-lg"></i> Putar Murottal Surah
                    </button>
                    <button id="btn-dl-${surah.nomor}" onclick="triggerManualDownload('${surah.audio}', ${surah.nomor})" class="w-11 h-11 bg-slate-800 text-yellow-400 border border-yellow-500/50 rounded-xl hover:bg-slate-700 flex items-center justify-center transition-all cursor-pointer shadow-md active:scale-90" title="Simpan Offline di Peramban Ini">
                        <i class="fa-solid fa-floppy-disk text-lg"></i>
                    </button>
                </div>
            `;
            
            const ayatContainer = document.getElementById('ayat-container');
            ayatContainer.innerHTML = '';
            surah.ayat.forEach((ayat) => {
                const box = document.createElement('div');
                box.id = `ayat-box-${ayat.nomor}`; 
                box.className = 'bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800 flex flex-col gap-3 shadow-xs';
                box.innerHTML = `
                    <div class="flex justify-between items-start gap-4">
                        <span class="bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-[10px] font-bold px-2 py-1 rounded-md font-mono-tech border border-slate-200 dark:border-slate-700">${surah.nomor}:${ayat.nomor}</span>
                        <p class="font-arabic text-2xl text-right leading-loose text-slate-900 dark:text-slate-100 flex-1 select-all" dir="rtl">${ayat.ar}</p>
                    </div>
                    <div class="border-t border-slate-100 dark:border-slate-800 pt-3 mt-2">
                        <p class="text-xs text-teal-600 dark:text-teal-400 italic font-medium mb-1.5">${ayat.tr}</p>
                        <p class="text-[13px] text-slate-600 dark:text-slate-300 leading-relaxed">${ayat.id}</p>
                    </div>
                `;
                ayatContainer.appendChild(box);
            });
            
            checkDownloadStatusInUI(surah.nomor);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showSurahList() {
            document.getElementById('surah-detail-section').classList.add('hidden');
            document.getElementById('surah-list-section').classList.remove('hidden');
        }

        // --- CHATBOT TERMINAL PROCESSOR ENGINE & TEKS BANTUAN CHAT ---
        function toggleChatWindow() { document.getElementById('chatWindow').classList.toggle('hidden'); }
        
        // FITUR BARU: Menampilkan daftar rekomendasi teks bantuan autocomplete di dalam kolom Chatbot Muslim
        function showChatInputSuggestions() {
            const chatInput = document.getElementById('chatInput');
            const chatSuggestionBox = document.getElementById('chat-suggestions');
            const query = chatInput.value.toLowerCase().trim();

            if(!query) {
                chatSuggestionBox.classList.add('hidden');
                return;
            }

            // Bersihkan query dari prefix perintah ketik bantuan
            const cleanQuery = query.replace('surah', '').trim();

            const filteredSurah = allSurahData.filter(s => 
                s.nama.toLowerCase().includes(cleanQuery) || s.arti.toLowerCase().includes(cleanQuery)
            );

            if(filteredSurah.length > 0 && cleanQuery.length > 0) {
                chatSuggestionBox.innerHTML = '';
                chatSuggestionBox.classList.remove('hidden');

                filteredSurah.slice(0, 3).forEach(surah => {
                    const row = document.createElement('div');
                    row.className = 'p-1.5 text-slate-300 hover:bg-teal-950 hover:text-teal-400 rounded cursor-pointer transition-colors border-b border-slate-900 last:border-none flex justify-between items-center';
                    row.innerHTML = `
                        <span>&gt; Cari Surah: <b class="text-yellow-400">${surah.nama}</b></span>
                        <span class="text-[9px] text-slate-500 font-sans">Klik untuk mengisi</span>
                    `;
                    row.onclick = () => {
                        chatInput.value = `Surah ${surah.nama}`;
                        chatSuggestionBox.classList.add('hidden');
                        chatInput.focus();
                    };
                    chatSuggestionBox.appendChild(row);
                });
            } else {
                chatSuggestionBox.classList.add('hidden');
            }
        }

