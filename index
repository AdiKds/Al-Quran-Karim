                                    <span class="bg-teal-950 text-teal-400 font-mono-tech font-bold px-2 py-0.5 rounded text-[10px]">${foundSurah.nomor}</span>
                                    <span class="font-arabic text-yellow-500 font-bold text-lg">${foundSurah.asma}</span>
                                </div>
                                <div>
                                    <h5 class="text-white font-bold text-sm font-mono-tech">${foundSurah.nama}</h5>
                                    <p class="text-[11px] text-slate-400">${foundSurah.arti} • ${foundSurah.type} (${foundSurah.ayat.length} Ayat)</p>
                                </div>
                                <div class="grid grid-cols-2 gap-2 pt-1 font-mono-tech">
                                    <button onclick="openSurah(${foundSurah.nomor}); toggleChatWindow();" class="py-1.5 bg-teal-700 hover:bg-teal-600 text-white font-bold rounded-lg text-[10px] cursor-pointer text-center transition-colors">
                                        <i class="fa-solid fa-book-open mr-1"></i> Buka Surah
                                    </button>
                                    <button onclick="playSurahAudio('${foundSurah.audio}', '${foundSurah.nama}', ${foundSurah.nomor});" class="py-1.5 bg-yellow-500 hover:bg-yellow-400 text-slate-950 font-bold rounded-lg text-[10px] cursor-pointer text-center transition-colors">
