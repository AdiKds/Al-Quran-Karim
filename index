                        insertBotReply("Surah tidak ditemukan. Coba ketikkan nama surah secara spesifik (contoh: *Al-Fatihah* atau *Al-Mulk*)."); 
                    }
                }
            }, 250);
            el.value = '';
        }

        function insertBotReply(html) {
            const msg = document.getElementById('chatMessages');
            msg.innerHTML += `<div class="bg-slate-950 p-2.5 rounded-xl border border-slate-800 text-slate-300 leading-relaxed">${html}</div>`;
            msg.scrollTop = msg.scrollHeight;
        }

        // --- SCREENSAVER ---
        function activateScreensaver(event) {
            if(event) event.stopPropagation();
            isScreensaverActive = true;
            document.getElementById('islamicScreensaverQuoteText').innerText = islamicQuotes[currentQuoteIndex];
            const el = document.getElementById('islamicScreensaver');
            el.classList.remove('hidden');
            setTimeout(() => { el.classList.remove('opacity-0'); el.classList.add('opacity-100'); }, 30);
            updateDateTime();
        }

        function deactivateScreensaver() {
            if(!isScreensaverActive) return;
            isScreensaverActive = false;
            const el = document.getElementById('islamicScreensaver');
            el.classList.remove('opacity-100'); el.classList.add('opacity-0');
            setTimeout(() => el.classList.add('hidden'), 500);
        }

        document.getElementById('islamicScreensaver').addEventListener("click", function() {
            deactivateScreensaver();
        });

        // --- MODAL LAYERS CONTROL ---
        function openCreatorModalOutside() { document.getElementById('creatorModalOutside').classList.remove('hidden'); }
        function closeCreatorModalOutside() { document.getElementById('creatorModalOutside').classList.add('hidden'); }
        function openHelpModal() { document.getElementById('helpModal').classList.remove('hidden'); }
        function closeHelpModal() { document.getElementById('helpModal').classList.add('hidden'); }

        // Start Bootstrapping Engine
        initIndexedDB();
        updateDateTime();
    </script>
