<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Al-Qur'an Digital Pro - Cyber Islamic Edition</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Amiri&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        .font-arabic { font-family: 'Amiri', serif; }
        .font-sans { font-family: 'Plus Jakarta Sans', sans-serif; }
        .font-mono-tech { font-family: 'JetBrains Mono', monospace; }
        
        /* Custom Scrollbar */
        .custom-scroll::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .dark .custom-scroll::-webkit-scrollbar-thumb { background: #475569; }

        /* Override Mode Dark Menyeluruh */
        html.dark body { background-color: #020617; color: #f8fafc; }
        
        /* Animasi Pijar (Glowing Effect) */
        @keyframes cyber-glow {
            0%, 100% { box-shadow: 0 0 15px rgba(20, 184, 166, 0.2), inset 0 0 10px rgba(20, 184, 166, 0.1); border-color: rgba(20, 184, 166, 0.3); }
            50% { box-shadow: 0 0 25px rgba(234, 179, 8, 0.4), inset 0 0 15px rgba(234, 179, 8, 0.15); border-color: rgba(234, 179, 8, 0.6); }
        }
        .animate-cyber-glow { animation: cyber-glow 4s infinite ease-in-out; }

        @keyframes gold-glow {
            0%, 100% { text-shadow: 0 0 10px rgba(234, 179, 8, 0.4); filter: drop-shadow(0 0 4px rgba(234, 179, 8, 0.2)); }
            50% { text-shadow: 0 0 20px rgba(234, 179, 8, 0.9), 0 0 30px rgba(234, 179, 8, 0.5); filter: drop-shadow(0 0 15px rgba(234, 179, 8, 0.7)); }
        }
        .animate-gold-glow { animation: gold-glow 2.5s infinite ease-in-out; }

        /* Efek Glow Keemasan Luar Frame Interaktif */
        @keyframes gold-glow-box {
            0%, 100% { box-shadow: 0 0 15px rgba(234, 179, 8, 0.3); border-color: rgba(234, 179, 8, 0.5); }
            50% { box-shadow: 0 0 30px rgba(234, 179, 8, 0.7); border-color: rgba(234, 179, 8, 0.9); }
        }
        .animate-gold-glow-box { animation: gold-glow-box 3s infinite ease-in-out; }

        /* Animasi Teks Menyala Keemasan Menarik */
        @keyframes gold-text-glow {
            0%, 100% { text-shadow: 0 0 4px rgba(234, 179, 8, 0.3); color: #f8fafc; }
            50% { text-shadow: 0 0 12px rgba(234, 179, 8, 0.8), 0 0 18px rgba(234, 179, 8, 0.4); color: #fef08a; }
        }
        .animate-gold-text-glow { animation: gold-text-glow 3s infinite ease-in-out; }

        /* Animasi Transisi Quotes */
        .quote-fade { transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out; }
        .quote-hidden { opacity: 0; transform: translateY(12px); }

        /* Efek Transisi Highlight Audio Mengalir */
        .audio-active-highlight {
            border-color: #14b8a6 !important;
            background-color: rgba(20, 184, 166, 0.06) !important;
            box-shadow: 0 0 20px rgba(20, 184, 166, 0.15) !important;
            transition: all 0.4s ease-in-out;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 dark:text-slate-100 transition-colors duration-300 min-h-screen flex flex-col font-sans relative pb-32">

    <!-- Global App Loader -->
    <div id="globalAppLoader" class="fixed inset-0 z-[10000] bg-slate-950 flex flex-col items-center justify-center transition-opacity duration-700 ease-in-out">
        <div class="relative flex flex-col items-center max-w-md px-6 text-center">
            <div class="w-28 h-28 mb-6 rounded-full border border-yellow-500/30 flex items-center justify-center relative bg-slate-900 shadow-[0_0_40px_rgba(234,179,8,0.15)]">
                <div class="absolute inset-0 rounded-full border-2 border-yellow-500 border-t-transparent animate-spin" style="animation-duration: 3s;"></div>
                <i class="fa-solid fa-book-quran text-yellow-500 text-5xl animate-gold-glow"></i>
            </div>
            <h2 class="font-arabic text-3xl md:text-4xl text-yellow-500 mb-3 tracking-wide animate-gold-glow select-none" dir="rtl">
                بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
            </h2>
            <p id="loaderStatusText" class="font-mono-tech text-xs text-cyan-400 tracking-widest animate-pulse mt-2">&gt;_ MEMUAT DATABASE MUSHAF DIGITAL</p>
            <div class="w-56 h-1 bg-slate-800 mt-6 rounded-full overflow-hidden relative">
                <div id="loaderProgressBar" class="h-full bg-gradient-to-r from-yellow-500 to-cyan-500 w-0 transition-all duration-300"></div>
            </div>
        </div>
    </div>

    <!-- Islamic Screensaver -->
    <div id="islamicScreensaver" class="hidden fixed inset-0 z-[9999] bg-slate-950 flex flex-col items-center justify-center overflow-hidden font-sans select-none transition-all duration-500 opacity-0">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(234,179,8,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(234,179,8,0.02)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
        <div class="z-10 text-center px-6 max-w-2xl flex flex-col items-center relative">
            <i class="fa-solid fa-mosque text-yellow-500/60 text-5xl mb-6"></i>
            <div id="scClockDisplay" class="text-6xl md:text-8xl font-black font-mono-tech text-transparent bg-clip-text bg-gradient-to-b from-white via-slate-200 to-slate-500 tracking-wider filter drop-shadow-[0_0_20px_rgba(255,255,255,0.15)]">00:00:00</div>
            <div id="scDateDisplay" class="text-xs md:text-sm font-mono-tech text-yellow-500 tracking-widest uppercase mt-2 border border-yellow-500/30 px-4 py-1.5 rounded-full bg-slate-900/40 backdrop-blur-xs">Memuat Kalender...</div>
            
            <div class="mt-12 p-6 rounded-2xl border-2 bg-slate-900/90 backdrop-blur-md shadow-2xl relative min-h-[120px] flex items-center justify-center animate-gold-glow-box" onclick="event.stopPropagation()">
                <i class="fa-solid fa-quote-left absolute -top-4 -left-2 text-yellow-500 text-4xl filter drop-shadow-[0_0_8px_rgba(234,179,8,0.6)]"></i>
                <p id="islamicScreensaverQuoteText" class="text-sm md:text-base font-medium italic leading-relaxed animate-gold-text-glow">
                    "Maka sesungguhnya beserta kesulitan ada kemudahan." (QS. Al-Insyirah: 5)
                </p>
            </div>
            <div class="mt-16 text-slate-600 font-mono-tech text-[10px] tracking-[0.3em] uppercase animate-pulse">
                <i class="fa-solid fa-keyboard mr-1"></i> Gunakan Panah Kanan/Kiri untuk Ganti Quotes • Tekan Esc untuk Kembali
            </div>
        </div>
    </div>

    <!-- Audio Player Widget -->
    <div id="audioPlayerWidget" class="fixed top-20 left-1/2 transform -translate-x-1/2 z-[100] bg-slate-900 border border-teal-500 p-2 rounded-full shadow-[0_0_20px_rgba(20,184,166,0.3)] hidden items-center gap-3 animate-cyber-glow">
        <div class="bg-teal-800 text-white px-4 py-1.5 rounded-full text-xs font-bold whitespace-nowrap min-w-[120px] text-center shadow-inner" id="audioSurahTitle">Murottal</div>
        <audio id="globalAudio" controls class="h-8 outline-none rounded-full"></audio>
        <button onclick="closeAudioPlayer()" class="w-8 h-8 bg-slate-800 hover:bg-red-500 text-slate-300 hover:text-white border border-slate-700 hover:border-red-400 rounded-full flex items-center justify-center cursor-pointer shadow-md transition-colors">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <!-- Header Section -->
    <header class="bg-teal-600 dark:bg-slate-900 text-white shadow-md sticky top-0 z-40 border-b border-teal-500/30 dark:border-slate-800 transition-colors">
        <div class="container mx-auto px-4 py-3 flex flex-col lg:flex-row justify-between items-center gap-3">
            <div class="flex items-center gap-3 cursor-pointer" onclick="showSurahList()">
                <span class="text-2xl">🕌</span>
                <div>
                    <h1 class="text-xl font-bold tracking-wide flex items-center gap-2">Al-Qur'an Digital Pro <span class="text-xs bg-teal-700 dark:bg-slate-800 px-2 py-0.5 rounded border border-teal-500/40 text-yellow-400 font-sans font-bold">Versi 1.0</span></h1>
                    <p class="text-xs text-teal-100 opacity-80 dark:text-slate-400 font-mono-tech">Core-Repository Database Offline</p>
                </div>
            </div>
            
            <div class="flex flex-wrap items-center gap-2.5 w-full lg:w-auto justify-between lg:justify-end">
                <div class="flex items-center gap-1.5 order-2 lg:order-1">
                    <button onclick="toggleFloatingQuotes()" class="bg-teal-700 hover:bg-teal-800 dark:bg-slate-800 dark:hover:bg-slate-700 text-yellow-400 text-xs font-bold px-2.5 py-2 rounded-xl border border-teal-500/40 dark:border-slate-700 shadow-xs cursor-pointer flex items-center gap-1" title="Tampilkan/Sembunyikan Quotes">
                        <i class="fa-solid fa-quote-left"></i> <span class="hidden sm:inline">QUOTES</span>
                    </button>
                    <button onclick="openCreatorModalOutside()" class="bg-amber-500 hover:bg-amber-600 dark:bg-amber-600 dark:hover:bg-amber-700 text-slate-950 dark:text-white text-xs font-bold px-2.5 py-2 rounded-xl border border-amber-400/40 shadow-xs cursor-pointer flex items-center gap-1 animate-pulse" title="Buka Data Pengembang">
                        <i class="fa-solid fa-code"></i> <span class="hidden sm:inline">CREDIT PROG</span>
                    </button>
                </div>

                <div class="bg-teal-700 dark:bg-slate-950 px-3 py-1.5 rounded-xl border border-teal-500/30 dark:border-slate-800 text-xs sm:text-sm order-1 lg:order-2">
                    <span id="dashboard-date" class="font-medium">Memuat hari...</span>
                    <span class="mx-1.5">|</span>
                    <span id="dashboard-time" class="font-mono-tech font-bold text-yellow-400 dark:text-teal-400">00:00:00</span>
                </div>
                
                <div class="flex items-center gap-1.5 order-3">
                    <button onclick="openHelpModal()" class="bg-slate-900 dark:bg-slate-800 hover:bg-slate-800 text-teal-400 dark:text-teal-300 text-xs font-bold p-2 rounded-xl border border-teal-500/30 dark:border-slate-700 shadow-xs cursor-pointer" title="Help System">
                        <i class="fa-solid fa-circle-question text-sm"></i>
                    </button>
                    <button onclick="toggleTheme()" class="p-2 rounded-xl bg-teal-700 dark:bg-slate-800 hover:bg-teal-50 dark:hover:bg-slate-700 text-white dark:text-teal-400 border border-teal-500/20 dark:border-slate-700 transition-all cursor-pointer shadow-xs" title="Ubah Mode Visual Halaman">
                        <span id="theme-icon">🌙</span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Container -->
    <div class="container mx-auto px-4 py-6 flex-1 flex flex-col lg:flex-row gap-6 relative">
        
        <!-- Sidebar Menu -->
        <aside class="w-full lg:w-72 shrink-0 lg:sticky lg:top-24 lg:h-[calc(100vh-8rem)] bg-white dark:bg-slate-900 rounded-2xl p-4 shadow-md border border-slate-200 dark:border-slate-800 flex flex-col justify-between order-2 lg:order-1 transition-all">
            <div>
                <h2 class="text-xs font-bold text-teal-600 dark:text-teal-400 uppercase tracking-wider mb-3 flex items-center justify-between">
                    <span class="flex items-center gap-1"><i class="fa-solid fa-star-and-crescent text-amber-500"></i> Indeks Mushaf</span>
                    <span class="text-[10px] bg-teal-50 dark:bg-slate-800 px-2 py-0.5 rounded text-teal-600 dark:text-teal-400 font-mono-tech" id="surah-counter">0/114</span>
                </h2>
                <div id="sidebar-menu" class="space-y-1 h-56 lg:h-[calc(100vh-14rem)] overflow-y-auto custom-scroll pr-1">
                    <div class="text-center py-4 text-slate-400 text-xs animate-pulse">Menyusun indeks surah...</div>
                </div>
            </div>
            <div class="hidden lg:flex items-center justify-between pt-3 border-t border-slate-200 dark:border-slate-800 text-[10px] text-slate-400 dark:text-slate-500 font-mono-tech">
                <span>Kernel V.2.5-Alquran</span>
                <span class="text-emerald-500 font-bold">● ONLINE</span>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="flex-1 order-1 lg:order-2 min-w-0 flex flex-col gap-5">
            <section id="surah-list-section" class="relative">
                <div class="relative w-full">
                    <input type="text" id="search-input" placeholder="Cari nama surah atau arti makna (contoh: Al-Baqarah)..." 
                        class="w-full p-4 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-xs focus:ring-2 focus:ring-teal-500 dark:focus:ring-teal-400 focus:outline-none transition-all text-slate-900 dark:text-white font-medium"
                        oninput="filterSurahWithSuggestion()">
                    
                    <!-- KOTAK TEKS BANTUAN AUTOCOMPLETE PENCARIAN UTAMA -->
                    <div id="search-suggestions" class="hidden absolute left-0 right-0 top-full mt-1.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-2xl z-50 max-h-48 overflow-y-auto custom-scroll p-1 font-sans"></div>
                </div>
                
                <div id="surah-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 hidden mt-4">
                </div>
            </section>

            <section id="surah-detail-section" class="hidden">
                <button onclick="showSurahList()" class="mb-5 flex items-center gap-2 text-teal-600 dark:text-teal-400 font-semibold hover:underline cursor-pointer text-sm bg-white dark:bg-slate-900 py-2 px-4 rounded-xl shadow-xs border border-slate-200 dark:border-slate-800 w-fit">
                    <i class="fa-solid fa-chevron-left text-xs"></i> Kembali ke Beranda
                </button>
                <div id="surah-info" class="bg-gradient-to-br from-teal-600 to-emerald-700 dark:from-slate-900 dark:to-teal-950 text-white p-6 rounded-2xl shadow-md mb-5 text-center border border-teal-500/20 flex flex-col items-center">
                </div>
                <div id="ayat-container" class="space-y-4">
                </div>
            </section>
        </main>
    </div>

    <!-- Floating Quote Widget -->
    <div id="floatingQuoteWidget" class="hidden fixed bottom-20 left-1/2 transform -translate-x-1/2 z-[90] w-80 sm:w-96 bg-slate-900/95 backdrop-blur-md p-4 rounded-2xl border-2 border-yellow-600 shadow-2xl flex flex-col gap-3 transition-all animate-gold-glow-box">
        <div class="flex justify-between items-center border-b border-slate-800 pb-2">
            <h3 class="text-[11px] font-bold text-yellow-400 uppercase tracking-wider flex items-center gap-1.5 font-mono-tech">
                <i class="fa-solid fa-kaaba text-yellow-500"></i> Mutiara Kearifan Islami
            </h3>
            <div class="flex items-center gap-1 text-xs font-mono-tech">
                <button onclick="navigateQuote(-1)" class="px-2 py-0.5 bg-slate-800 hover:bg-slate-700 text-yellow-400 rounded cursor-pointer transition-all border border-slate-700 shadow-xs">&lt;</button>
                <button onclick="navigateQuote(1)" class="px-2 py-0.5 bg-slate-800 hover:bg-slate-700 text-yellow-400 rounded cursor-pointer transition-all border border-slate-700 shadow-xs">&gt;</button>
                <button onclick="toggleFloatingQuotes()" class="ml-2 text-slate-400 hover:text-red-500 px-1.5 py-0.5 cursor-pointer rounded-sm bg-slate-800 border border-slate-700 transition-colors" title="Tutup Widget"><i class="fa-solid fa-xmark text-xs"></i></button>
            </div>
        </div>
        
        <div class="min-h-[70px] flex items-center justify-center text-center px-1">
            <p id="dashboardQuoteText" class="quote-fade text-sm font-medium italic leading-relaxed animate-gold-text-glow">
                Memuat data kutipan rohani...
            </p>
        </div>
    </div>

    <!-- Right Bottom Interactive Buttons -->
    <div class="fixed bottom-4 right-4 z-50 flex items-center gap-2.5">
        <!-- Chat Bot Terminal UI Container -->
        <div id="chatWindow" class="w-80 sm:w-96 h-[460px] bg-slate-900 border-2 border-slate-700 rounded-2xl flex flex-col overflow-hidden hidden transition-all duration-300 shadow-2xl absolute bottom-14 right-0">
            <div class="bg-gradient-to-r from-slate-950 to-teal-950 p-3 border-b border-slate-800 flex flex-col gap-1.5 select-none relative">
                <div class="flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-star-and-crescent text-yellow-400 text-xs animate-pulse"></i>
                        <h4 class="font-mono-tech text-xs font-black text-slate-300">ASISTEN CHAT MUSLIM</h4>
                    </div>
                    <button onclick="toggleChatWindow()" class="text-slate-400 hover:text-white cursor-pointer text-xs"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <div class="flex flex-col sm:flex-row justify-between items-center bg-slate-950/90 px-3 py-2 rounded-xl border border-teal-500/40 font-mono-tech gap-1 shadow-inner">
                    <span id="chat-top-day" class="text-slate-200 text-[11px] sm:text-xs font-bold tracking-wide">Memuat Hari...</span>
                    <span id="chat-top-clock" class="text-sm font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-teal-300 to-emerald-400 filter drop-shadow-[0_0_8px_rgba(34,211,238,0.4)]">00:00:00 WIB</span>
                </div>
            </div>
            
            <div id="chatMessages" class="flex-1 p-3 overflow-y-auto space-y-3 font-mono-tech text-xs text-slate-200 bg-slate-950 custom-scroll relative">
                <div class="bg-slate-900/80 p-2.5 rounded-xl border border-slate-800 leading-relaxed">
                    <span class="text-yellow-400 block font-bold mb-1">&gt;_ SISTEM DIGITAL AKTIF:</span>
                    Assalamualaikum! Silakan ketik langsung **nama surah** (contoh: *Al-Mulk* atau *Yasin*) untuk mencari dan menampilkan surah yang Anda tuju dengan cepat.
                </div>
            </div>

            <!-- CONTAINER WIDGET TEKS BANTUAN AUTOCOMPLETE CHATBOT -->
            <div id="chat-suggestions" class="hidden mx-2 p-1 bg-slate-950 border border-slate-800 rounded-lg max-h-24 overflow-y-auto custom-scroll font-mono-tech text-[11px] space-y-0.5 z-50"></div>

            <div class="p-2 bg-slate-900 border-t border-slate-800 flex gap-1.5 overflow-x-auto hide-scrollbar shrink-0">
                <button onclick="triggerChatShortcut('help')" class="whitespace-nowrap px-2.5 py-1 bg-slate-950 hover:bg-emerald-950 text-emerald-400 text-[10px] rounded border border-emerald-900 font-bold cursor-pointer"><i class="fa-solid fa-circle-question mr-1"></i>Help System</button>
                <button onclick="triggerChatShortcut('cari_surah')" class="whitespace-nowrap px-2.5 py-1 bg-slate-950 hover:bg-blue-950 text-blue-400 text-[10px] rounded border border-blue-900 font-bold cursor-pointer"><i class="fa-solid fa-magnifying-glass mr-1"></i>Cari Surah</button>
                <button onclick="triggerChatShortcut('cari_ayat')" class="whitespace-nowrap px-2.5 py-1 bg-slate-950 hover:bg-amber-950 text-amber-400 text-[10px] rounded border border-amber-900 font-bold cursor-pointer"><i class="fa-solid fa-book-open mr-1"></i>Cari Ayat</button>
                <button onclick="triggerChatShortcut('programmer')" class="whitespace-nowrap px-2.5 py-1 bg-fuchsia-950 hover:bg-fuchsia-900 text-fuchsia-400 text-[10px] rounded border border-fuchsia-800 font-black cursor-pointer"><i class="fa-solid fa-code mr-1"></i>Data Programmer</button>
            </div>

            <div class="p-2 bg-slate-900 border-t border-slate-800 flex gap-1.5">
                <input type="text" id="chatInput" oninput="showChatInputSuggestions()" onkeydown="if(event.key==='Enter') processChatMessage()" placeholder="Ketik nama surah di sini..." class="flex-1 bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-white focus:outline-none focus:border-cyan-400 font-mono-tech">
                <button onclick="processChatMessage()" class="bg-teal-700 hover:bg-teal-600 text-white px-3 rounded-lg text-xs font-bold cursor-pointer flex items-center justify-center"><i class="fa-solid fa-paper-plane"></i></button>
            </div>
        </div>

        <!-- Tombol Icon Quote -->
        <button onclick="toggleFloatingQuotes()" class="bg-slate-900 dark:bg-slate-800 border border-teal-500 w-11 h-11 rounded-full shadow-lg flex items-center justify-center text-teal-400 cursor-pointer hover:scale-105 transition-transform" title="Buka/Tutup Quotes">
            <i class="fa-solid fa-quote-left text-sm"></i>
        </button>

        <!-- Screensaver Active Trigger Button -->
        <button onclick="activateScreensaver(event)" class="bg-gradient-to-r from-slate-900 to-indigo-950 border border-purple-500/80 w-11 h-11 rounded-full shadow-lg flex items-center justify-center text-purple-400 cursor-pointer hover:scale-105 transition-transform" title="Aktifkan Screensaver Rohani">
            <i class="fa-solid fa-desktop text-sm"></i>
        </button>

        <!-- Chat Activation Trigger Button -->
        <button onclick="toggleChatWindow()" class="bg-slate-950 hover:bg-slate-900 border-2 border-yellow-500 w-12 h-12 rounded-full shadow-lg flex items-center justify-center text-xl cursor-pointer transition-transform active:scale-90" title="Buka Asisten Chat Muslim">
            <div class="relative flex items-center justify-center text-yellow-500">
                <i class="fa-solid fa-comment-sms text-base absolute -top-1 -right-1 opacity-40"></i>
                <i class="fa-solid fa-user-astronaut text-sm"></i>
            </div>
        </button>
    </div>

    <!-- Developer Credentials Layout -->
    <div id="creatorModalOutside" class="fixed inset-0 z-[10005] hidden bg-black/75 backdrop-blur-xs flex items-center justify-center p-4">
        <div class="bg-[#0b1224] border-2 border-yellow-500 rounded-2xl w-full max-w-md p-6 shadow-2xl relative select-none animate-gold-glow-box">
            
            <button onclick="closeCreatorModalOutside()" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors cursor-pointer z-10"><i class="fa-solid fa-xmark text-xl"></i></button>
            
            <div class="font-mono-tech flex flex-col items-center text-center">
                <div class="border border-yellow-500/60 rounded-full px-4 py-1 mb-4 bg-slate-950 text-[10px] text-yellow-500 font-extrabold tracking-widest uppercase flex items-center gap-1.5 shadow-sm">
                    <i class="fa-solid fa-arrows-up-down-left-right text-[9px]"></i> HOLD AND DRAG WINDOW
                </div>

                <div class="w-16 h-16 rounded-full border-2 border-yellow-500 bg-slate-900/60 flex items-center justify-center mb-3 shadow-[0_0_15px_rgba(234,179,8,0.2)]">
                    <i class="fa-solid fa-user-gear text-yellow-500 text-2xl"></i>
                </div>
                
                <h3 class="text-yellow-400 text-xl font-extrabold tracking-wide uppercase font-mono-tech filter drop-shadow-[0_0_4px_rgba(234,179,8,0.5)]">
                    MOHAMAD HARTADI (ADI)
