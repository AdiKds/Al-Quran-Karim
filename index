        function processChatMessage() {
            const el = document.getElementById('chatInput');
            const txt = el.value.trim();
            document.getElementById('chat-suggestions').classList.add('hidden'); // Sembunyikan boks bantuan otomatis saat kirim pesan
            
            if(!txt) return;
            
            document.getElementById('chatMessages').innerHTML += `<div class="bg-slate-800 p-2 rounded-xl text-right max-w-[85%] ml-auto text-white font-bold font-mono-tech">${txt}</div>`;
            const textLower = txt.toLowerCase();
            
            setTimeout(() => { 
                if (textLower.includes('programmer') || textLower.includes('hartadi') || textLower.includes('dev') || textLower.includes('kredit')) {
                    triggerChatShortcut('programmer');
                } else {
                    const cleanQuery = textLower.replace('surah', '').trim();
                    const foundSurah = allSurahData.find(s => 
                        s.nama.toLowerCase().includes(cleanQuery) || s.arti.toLowerCase().includes(cleanQuery)
                    );

                    if (foundSurah) {
                        let surahCardPayload = `
                            <div class="bg-slate-900 border border-teal-500 rounded-xl p-3 space-y-2.5 shadow-md font-sans text-xs">
